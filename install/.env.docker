# ============================================
# Variáveis de ambiente para docker-compose
# Copie este arquivo para .env antes de subir
# ============================================

# Senha do banco PostgreSQL
DB_PASSWORD=SuaSenhaForteAqui123!

# Senha URL-encoded (se tiver @, #, etc: @ → %40, # → %23)
DB_PASSWORD_URL_ENCODED=SuaSenhaForteAqui123!

# Segredo JWT (gere com: openssl rand -base64 64)
JWT_SECRET=troque-este-segredo-com-openssl-rand
